[Unit]
Description=Drive UGREEN front-panel LEDs from TrueNAS ZFS status
After=pve-guests.service

[Service]
Type=simple
ExecStart=/usr/local/bin/ugreen-truenas-zfs.py --start
ExecStopPost=/usr/local/bin/ugreen-truenas-zfs.py --stop
Restart=on-failure
RestartSec=10s
Nice=10

[Install]
WantedBy=multi-user.target
